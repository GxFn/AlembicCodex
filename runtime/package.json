{
  "name": "alembic-ai",
  "version": "0.1.0",
  "description": "Alembic — Auto Source Distill. Distill project knowledge from source code into structured recipes for humans and AI agents. Embedded Codex plugin runtime.",
  "type": "module",
  "main": "dist/lib/bootstrap.js",
  "engines": {
    "node": ">=22.0.0"
  },
  "imports": {
    "#shared/*": "./dist/lib/shared/*",
    "#infra/*": "./dist/lib/infrastructure/*",
    "#service/*": "./dist/lib/service/*",
    "#agent/*": "./dist/lib/agent/*",
    "#domain/*": "./dist/lib/domain/*",
    "#inject/*": "./dist/lib/injection/*",
    "#core/*": "./dist/lib/core/*",
    "#external/*": "./dist/lib/external/*",
    "#platform/*": "./dist/lib/platform/*",
    "#repo/*": "./dist/lib/repository/*",
    "#types/*": "./dist/lib/types/*",
    "#http/*": "./dist/lib/http/*",
    "#workflows/*": "./dist/lib/workflows/*",
    "#tools/*": "./dist/lib/tools/*",
    "#codex/*": "./dist/lib/codex/*",
    "#sandbox/*": "./dist/lib/sandbox/*"
  },
  "bin": {
    "alembic-codex-mcp": "dist/bin/codex-mcp.js"
  },
  "keywords": [
    "knowledge-base",
    "ai",
    "ai-agent",
    "mcp",
    "codex",
    "codex-plugin",
    "openai-codex",
    "copilot",
    "cursor",
    "code-review",
    "guard",
    "ast",
    "tree-sitter",
    "typescript",
    "javascript",
    "python",
    "swift",
    "rust",
    "kotlin",
    "developer-tools",
    "cli"
  ],
  "homepage": "https://github.com/GxFn/Alembic#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GxFn/Alembic.git"
  },
  "bugs": {
    "url": "https://github.com/GxFn/Alembic/issues"
  },
  "license": "MIT",
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "ajv": "^8.20.0",
    "better-sqlite3": "^12.6.2",
    "commander": "^14.0.3",
    "cors": "^2.8.6",
    "drizzle-orm": "^0.45.1",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "js-yaml": "^4.1.1",
    "minimist": "^1.2.8",
    "open": "^11.0.0",
    "ora": "^9.3.0",
    "p-limit": "^7.3.0",
    "socket.io": "^4.8.3",
    "undici": "^7.22.0",
    "uuid": "^13.0.0",
    "web-tree-sitter": "^0.26.6",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "overrides": {
    "minimatch": "^10.2.2",
    "diff": "^8.0.3",
    "glob": "^11.0.0"
  },
  "files": [
    ".agents",
    "channels",
    "config",
    "dashboard/dist",
    "dist",
    "injectable-skills",
    "plugins/alembic-codex",
    "resources",
    "templates",
    "template.json",
    "README.md",
    "README_CN.md"
  ]
}
